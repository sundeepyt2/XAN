# ─── REQUIRED: Backend URL (for the watch page to function) ───
# Points to XAN's built-in stream proxy by default.
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000/api"

# ─── RECOMMENDED: Consumet API instance (for real anime streaming) ───
# Self-host Consumet: https://github.com/consumet/api.consumet.org
# Then point CONSUMET_URL to your instance.
#
# ⚠️ The public api.consumet.org endpoint is DEAD (returns HTTP 451).
#    You MUST self-host Consumet for this to work.
#
# When set, XAN will:
#   1. GET {CONSUMET_URL}/anime/animepahe/info/{anilistId}     → episode list
#   2. GET {CONSUMET_URL}/anime/animepahe/watch?episodeId=...  → HLS/MP4 sources
# When unset or unreachable, XAN falls back to public demo HLS streams.
# CONSUMET_URL="https://your-consumet-instance.com"

# ─── OPTIONAL: Skip Intro/Outro timestamps ───
# NEXT_PUBLIC_SKIP_TIMES_URL="https://api.aniskip.com/"

# ─── OPTIONAL: CORS proxy for backend requests ───
# NEXT_PUBLIC_PROXY_URL=""
